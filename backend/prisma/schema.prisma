generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id          Int      @id @default(autoincrement())

  fullName    String
  title       String
  bio         String?

  avatar      String?
  coverImage  String?

  email       String
  phone       String?
  location    String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projects    Project[]
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  TESTING
  COMPLETED
  PAUSED
  ARCHIVED
}

model Project {
  id               Int           @id @default(autoincrement())

  title            String
  slug             String        @unique

  shortDescription String
  description      String

  image            String

  githubUrl        String?
  liveUrl          String?

  status           ProjectStatus @default(PLANNING)

  featured         Boolean       @default(false)

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  profileId        Int
  profile          Profile       @relation(fields: [profileId], references: [id])
}